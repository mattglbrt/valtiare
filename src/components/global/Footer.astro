---
// Images
import { Image } from "astro:assets";
import FooterImage from "@/images/footer.jpg";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const contentArray = [
  {
    section: "Thanks To",
    items: [
      {
        label: "Website",
        value: "Everyway Design",
        url: "https://everywaydesign.com"
      },
      {
        label: "Artwork",
        value: "Matt Gilbert",
        url: "https://mattglbrt.com"
      },
      {
        label: "Words",
        value: "Matt Gilbert",
        url: "https://mattglbrt.com"
      },
      {
        label: "Sponser",
        value: "The Hobbinomicon",
        url: "https://hobbinomicon.com"
      },
      {
        label: "Sponsor",
        value: "Buzzard's Trading Post",
        url: "https://buzzardstradingpost.com"
      },
    ],
  },
  
];
---

<footer class="bg-black">
  <Wrapper variant="standard" class="py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 text-white">
      <Image
        src={FooterImage}
        alt="#_"
        width="1000"
        height="1000"
        class="object-cover object-center size-full"
      />
      <div
        class="grid grid-cols-1 lg:grid-cols-2 bg-black lg:col-span-2 lg:col-start-2"
      >
        <div class="p-8 lg:col-span-2">
        <p>Valtiare</p>
        
        
        </div>
        
      </div>
      <div class="flex flex-col lg:col-span-full lg:col-row-3 bg-base-950">
        <div class="p-8 bg-base-950">
          <Text tag="span" variant="textBase">Terms | Privacy | Disclaimer | Copyright</Text>
        </div>
        <div class="p-8 flex flex-col gap-8">
          {
            contentArray.map((section) => (
              <div class="pt-2 border-t border-base-700">
                <div class="grid grid-cols-1 lg:grid-cols-3">
                  <div>{section.section}</div>
                  <nav role="navigation" class="col-span-2">
                    <ul
                      class="flex flex-col divide-y divide-base-700   font-medium lg:pl-4"
                      role="list"
                    >
                      {section.items.map((item) => (
                        <li class="py-1 grid grid-cols-2 gap-4 lg:grid-cols-2">
                          <Text tag="p" variant="textXS" >
                            {item.label}
                          </Text>
                          <Text tag="p" variant="textXS" class="ml-auto lg:ml-0 lg:pl-6">
                  {item.url ? (
                    <a href={item.url} class="text-white-500 no-underline hover:underline">
                      {item.value}
                    </a>
                  ) : (
                    item.value
                  )}
                </Text>
                        </li>
                      ))}
                    </ul>
                  </nav>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Wrapper>
</footer>
