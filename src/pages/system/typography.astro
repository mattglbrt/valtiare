---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import Divider from "@/components/assets/Divider.astro";
---

<BaseLayout>

  <Wrapper variant="standard">
    <div class="relative">
      <Text tag="h3" variant="display6XL" class="text-white font-display"
        >Typography</Text
      >
      <Divider />
    </div>
  </Wrapper>

  <Wrapper variant="standard" class="py-12">
    <div>
      <Text tag="h1" variant="textBase" class="font-medium text-white">
        All variants - Font in use: Inter - Inter Display
      </Text>
    </div>

    <div class="flex flex-col mt-8 font-medium text-white divide-y divide-base-900">
      <div class="py-4">
        <Text tag="p" variant="textXS"> Text XS </Text>
      </div>
      <div class="py-4">
        <Text tag="p" variant="textSM"> Text SM </Text>
      </div>

      <div class="py-4">
        <Text tag="p" variant="textBase"> Text Base </Text>
      </div>
      <div class="py-4">
        <Text tag="p" variant="textLG"> Text LG </Text>
      </div>
      <div class="py-4">
        <Text tag="p" variant="textXL"> Text XL </Text>
      </div>
      <div class="py-4">
        <Text tag="p" variant="displayXS" class="font-display">
          Display XS
        </Text>
      </div>
      <div class="py-4">
        <Text tag="p" variant="displaySM" class="font-display">
          Display SM
        </Text>
      </div>
      <div class="py-4">
        <Text tag="p" variant="displayMD" class="font-display">
          Display MD
        </Text>
      </div>
      <div class="py-4">
        <Text tag="p" variant="displayLG" class="font-display">
          Display LG
        </Text>
      </div>
      <div class="py-4">
        <Text tag="p" variant="displayXL" class="font-display">
          Display XL
        </Text>
      </div>
      <div class="py-4">
        <Text tag="p" variant="display2XL" class="font-display">
          Display 2XL
        </Text>
      </div>
      <div class="py-4">
        <Text tag="p" variant="display3XL" class="font-display">
          Display 3XL
        </Text>
      </div>
      <div class="py-4">
        <Text tag="p" variant="display4XL" class="font-display">
          Display 4XL
        </Text>
      </div>
      <div class="py-4">
        <Text tag="p" variant="display5XL" class="font-display">
          Display 5XL
        </Text>
      </div>
      <div class="py-4">
        <Text tag="p" variant="display6XL" class="font-display">
          Display 6XL
        </Text>
      </div>
    </div>
  </Wrapper>
</BaseLayout>
