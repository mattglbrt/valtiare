---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import Divider from "@/components/assets/Divider.astro";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard">
      <div class="relative">
        <Text tag="h3" variant="display6XL" class="text-white font-display"
          >Buttons</Text
        >
        <Divider />
      </div>
    </Wrapper>
    <Wrapper variant="standard" class="py-12">
      <div
        class="grid grid-cols-1 lg:grid-cols-3 gap-12 "
      >
        <div class="py-4">
          <Text tag="p" variant="textBase" class="text-white ">
            Default
          </Text>
          <div class="flex flex-wrap items-center gap-4 mt-2">
            <Button class="w-full" size="xs" variant="default">Default XS</Button>
            <Button class="w-full" size="sm" variant="default">Default SM</Button>
            <Button class="w-full" size="base" variant="default">Default Base</Button>
            <Button class="w-full" size="md" variant="default">Default MD</Button>
            <Button class="w-full" size="lg" variant="default">Default LG</Button>
            <Button class="w-full" size="xl" variant="default">Default XL</Button>
          </div>
        </div>
        <div class="py-4">
          <Text tag="p" variant="textBase" class="text-white ">
            Accent
          </Text>
          <div class="flex flex-wrap items-center gap-4 mt-2">
            <Button class="w-full" size="xs" variant="accent">Accent XS</Button>
            <Button class="w-full" size="sm" variant="accent">Accent SM</Button>
            <Button class="w-full" size="base" variant="accent">Accent Base</Button>
            <Button class="w-full" size="md" variant="accent">Accent MD</Button>
            <Button class="w-full" size="lg" variant="accent">Accent LG</Button>
            <Button class="w-full" size="xl" variant="accent">Accent XL</Button>
          </div>
        </div>
         <div class="py-4">
          <Text tag="p" variant="textBase" class="text-white ">
            Muted
          </Text>
          <div class="flex flex-wrap items-center gap-4 mt-2">
            <Button class="w-full" size="xs" variant="muted">Accent XS</Button>
            <Button class="w-full" size="sm" variant="muted">Accent SM</Button>
            <Button class="w-full" size="base" variant="muted">Accent Base</Button>
            <Button class="w-full" size="md" variant="muted">Accent MD</Button>
            <Button class="w-full" size="lg" variant="muted">Accent LG</Button>
            <Button class="w-full" size="xl" variant="muted">Accent XL</Button>
          </div>
        </div>
        
      </div>
    </Wrapper>
  </section>
</BaseLayout>
