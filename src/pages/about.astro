---
// Images
import { Image } from "astro:assets";
import Avatar1 from "@/images/avatars/1.jpeg";
import Avatar2 from "@/images/avatars/2.jpeg";
import AboutImage from "@/images/about.jpg";
// Import All images you need
import A from "@/images/about/a.jpeg";
import B from "@/images/about/b.jpeg";
import C from "@/images/about/c.jpeg";
import D from "@/images/about/d.jpeg";
import E from "@/images/about/e.jpeg";
const images = [
  { src: A, alt: "Alt text for image A" },
  { src: E, alt: "Alt text for image E" },
  { src: B, alt: "Alt text for image B" },
  { src: D, alt: "Alt text for image D" },
  { src: C, alt: "Alt text for image C" },
];
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard">
      <div
        class="relative flex flex-col items-start p-8 overflow-hidden bg-black isolate lg:p-12"
      >
        <Image
          src={AboutImage}
          alt="#_"
          width="1000"
          height="1000"
          class="absolute inset-0 object-cover object-top -z-10 size-full"
        />
        <div
          class="absolute inset-0 -z-10 bg-linear-360 from-black via-black/95 to-black/60"
        >
        </div>
        <div
          class="flex flex-col justify-between h-full gap-20 text-white lg:gap-50"
        >
          <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
            <Text tag="h1" variant="textXL" class="font-light lg:col-span-2"
              >Welcome to Perspectives in Architecture, a platform dedicated to
              exploring the art, science, and stories behind the spaces we
              inhabit <span class="italic text-base-200"
                >Our mission is to celebrate the creativity, innovation, and
                craftsmanship that shape the built environment, from ancient
                wonders to cutting-edge designs.</span
              ></Text
            >
            <div class="lg:row-start-4 col-span-full">
              <Text
                tag="p"
                variant="displayLG"
                class="font-light tracking-tight text-white leading-14 lg:leading-10 font-display indent-8 lg:indent-48"
                >Here, we bring together architects, designers, and enthusiasts
                to share insights, inspire ideas, and spark meaningful
                conversations about architecture’s impact on our lives and
                communities. Whether you’re passionate about preserving
                heritage, embracing sustainability, or exploring new design
                trends, you’ll find a home here.
              </Text>
            </div>
            <div class="lg:row-start-5 lg:col-start-2">
              <Text
                tag="p"
                variant="textBase"
                class="font-light text-white font-display first-letter:text-3xl"
              >
                Discover the stories behind the buildings, meet the visionaries
                redefining design, and join us in celebrating the timeless
                elegance and transformative power of architecture.</Text
              >
            </div>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>

  <section class="overflow-hidden">
    <Wrapper variant="standard" class="pt-12">
      <div class="flex flex-col gap-12">
        <div class="grid grid-cols-1 gap-12 md:grid-cols-6 items-en">
          <div class="space-y-12 lg:col-start-3">
            <Text
              tag="p"
              variant="textBase"
              class="font-light text-white font-display"
            >
              Dive into the world of architectural wonders as we uncover the
              stories behind iconic buildings, ancient ruins, and modern
              masterpieces. From towering skyscrapers to hidden gems in urban
              landscapes, we bring you closer to the artistry and innovation
              that define architecture across eras and cultures.
            </Text>
            <Text
              tag="p"
              variant="textBase"
              class="font-light text-white font-display "
            >
              Explore the rich history of architectural styles, from the
              grandeur of Gothic cathedrals to the sleek elegance of modernist
              design. We delve into the cultural significance and technical
              brilliance that make each structure a timeless testament to human
              creativity and ingenuity.
            </Text>
          </div>
          <div
            class="relative overflow-hidden isolate gap-80 bg-base-900 aspect-square lg:col-span-3 lg:col-start-4"
          >
            <Image
              src={Avatar1}
              alt="avatar"
              width="1000"
              height="1000"
              class="object-cover size-full"
            />
          </div>
        </div>

        <div class="grid items-start grid-cols-1 gap-12 md:grid-cols-6">
          <div
            class="relative overflow-hidden isolate gap-80 bg-base-900 aspect-square lg:col-span-3"
          >
            <Image
              src={Avatar2}
              alt="avatr"
              width="1000"
              height="1000"
              class="object-cover size-full"
            />
          </div>

          <Text
            tag="p"
            variant="textBase"
            class="font-light text-white font-display"
          >
            Stay inspired with tips, trends, and thought-provoking discussions
            on sustainable architecture, urban planning, and the future of
            design. Whether you’re an aspiring architect, a seasoned
            professional, or simply an admirer of beautiful spaces, there’s
            something here for everyone.
          </Text>
          <div class="lg:col-span-2">
            <Text
              tag="p"
              variant="textXL"
              class="font-light text-white font-display"
            >
              Join us on this journey of discovery and celebration, as we
              connect with architects, designers, and enthusiasts from around
              the world. Together, we’ll explore the stories and ideas that
              shape the spaces where we live, work, and dream.
              <br />
              <br />
              At the heart of our blog is a deep appreciation for the power of architecture
              to transform lives and communities. Through its blend of artistry and
              functionality, architecture tells stories, preserves history, and inspires
              progress. Let’s celebrate the visionaries and craftspeople who bring
              these structures to life, shaping the world one design at a time.
            </Text>
          </div>
        </div>
      </div>
    </Wrapper>
    <div class="py-24 overflow-hidden">
      <div class="flex gap-12">
        {
          [...images, ...images].map((image, index) => (
            <div class=" flex-none relative lg:aspect-[9/7]   shadow overflow-hidden w-100  lh:w-220 2xl:w-150 h-80 lg:h-130 2xl:h-200 -mx-4">
              <Image
                alt={image.alt}
                class="absolute inset-0 object-cover w-full h-full -z-10"
                src={image.src}
              />
              <div class="absolute inset-0 duration-300 -z-10 bg-linear-360 from-black to-black/20" />
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
