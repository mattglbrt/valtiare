---
// Images
import { Image } from "astro:assets";
import Error from "@/images/hero1.jpg";
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Link from "@/components/fundations/elements/Link.astro";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard">
      <div
        class="relative flex flex-col items-start p-8 overflow-hidden bg-black isolate lg:p-12"
      >
        <Image
          src={Error}
          alt="#_"
          width="1000"
          height="1000"
          class="absolute inset-0 object-cover object-top -z-10 size-full"
        />
        <div
          class="absolute inset-0 -z-10 bg-linear-360 from-black via-black/95 to-black/20"
        >
        </div>
        <div
          class="flex flex-col justify-between h-full gap-20 text-white lg:gap-10"
        >
          <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
            <Text
              tag="h3"
              variant="display6XL"
              class="text-white font-display row-start-1">404</Text
            >
            <Text tag="h1" variant="textXL" class="font-light lg:col-span-2"
              >Oops! It looks like you’ve wandered off the blueprint. The page
              you’re looking for doesn’t exist—or maybe it’s under renovation. <span
                class="italic text-base-200"
                >Don’t worry, even the best architects encounter detours!</span
              ></Text
            >
            <div class="lg:row-start-2 col-span-full">
              <Text
                tag="h3"
                variant="displayLG"
                class="font-light tracking-tight text-white leading-14 lg:leading-12 font-display indent-8 lg:indent-48"
                >Feel free to head back to our homepage to explore our latest
                stories, interviews, and architectural insights. Still stuck?
                Reach out to us, and we’ll help you get back on track. Thanks
                for visiting Perspectives in Architecture—where every design
                tells a story!"</Text
              >
            </div>
          </div>
          <div class="lg:ml-auto">
            <Link
              size="xl"
              class="w-auto"
              variant="default"
              href="/"
              title="See all posts"
            >
              Go back home
            </Link>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
