---
// Import image component
import { Image } from "astro:assets";
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// The props
const { frontmatter } = Astro.props;
---

<BaseLayout>
  <section>
    <Wrapper variant="standard">
      <div
        class="relative flex flex-col items-start p-8 overflow-hidden bg-black isolate lg:p-12"
      >
        <Image
          src={frontmatter.image.url}
          alt={frontmatter.image.alt}
          width="1000"
          height="1000"
          class="absolute inset-0 object-cover object-top -z-10 size-full"
        />
        <div
          class="absolute inset-0 -z-10 bg-linear-360 from-black via-black/95 to-black/60"
        >
        </div>
        <div
          class="flex flex-col justify-between h-full gap-20 text-white lg:gap-50"
        >
          <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
            <Text tag="h1" variant="textXL" class="font-light lg:col-span-2">
              {frontmatter.name} — <span class="italic text-base-200"
                >{frontmatter.role}</span
              ></Text
            >
            <div class="lg:row-start-4 lg:col-start-2 lg:col-span-2">
              <Text
                tag="p"
                variant="displaySM"
                class="font-light text-white font-display indent-8 lg:indent-32 lg:leading-8"
                >
                {frontmatter.description}</Text
              >
            </div>
           
            <div class="lg:row-start-5 col-span-full">
              <Image
                width="1000"
                height="1000"
                src={frontmatter.image.url}
                alt={frontmatter.image.alt}
                class="object-cover object-top w-full max-h-150"
              />
            </div>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>

  <section >
    <Wrapper variant="standard" class="pb-12">
      <div class="mx-auto prose-styles">
        <slot />
      </div>
    </Wrapper>
  </section>
</BaseLayout>
